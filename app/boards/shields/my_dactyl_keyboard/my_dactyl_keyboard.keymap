&lc_dcs RAISE_LOWER_DCS_SHFT &hidiokp 24 &hidiokp 23 &hidiokp 22 &hidiokp 21 &hidiokp 20                    &hidiokp 20 &hidiokp 21 &hidiokp 22 &hidiokp 23 &hidiokp 24 &lc_dcs RAISE_LOWER_DCS_SHFT
